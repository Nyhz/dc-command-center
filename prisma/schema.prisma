generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─── Auth.js v5 required models ───

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ─── Enums ───

enum GuildRole {
  GUILD_MASTER
  RAID_LEADER
  OFFICER
  MEMBER
}

enum RaidRole {
  TANK
  HEALER
  DPS
}

enum AttendanceStatus {
  ATTENDING
  ABSENT
  TENTATIVE
}

// ─── Guild models ───

model Guild {
  id        String   @id @default(cuid())
  name      String
  realm     String
  region    String   @default("eu")
  slug      String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  members    GuildMember[]
  characters Character[]
  raidEvents RaidEvent[]
  raidLogs   RaidLog[]
  invites    GuildInvite[]

  @@unique([name, realm, region])
}

model GuildMember {
  id        String    @id @default(cuid())
  userId    String
  guildId   String
  role      GuildRole @default(MEMBER)
  joinedAt  DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  guild Guild @relation(fields: [guildId], references: [id], onDelete: Cascade)

  @@unique([userId, guildId])
}

model GuildInvite {
  id        String    @id @default(cuid())
  guildId   String
  code      String    @unique
  createdBy String
  expiresAt DateTime?
  maxUses   Int?
  uses      Int       @default(0)
  createdAt DateTime  @default(now())

  guild Guild @relation(fields: [guildId], references: [id], onDelete: Cascade)
}

// ─── User model ───

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  battleTag     String?   @unique
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts         Account[]
  sessions         Session[]
  characters       Character[]
  guildMemberships GuildMember[]
}

// ─── Character model ───

model Character {
  id         String   @id @default(cuid())
  name       String
  realm      String
  region     String   @default("eu")
  className  String
  specName   String?
  raidRole   RaidRole @default(DPS)
  itemLevel  Int      @default(0)
  guildRank  Int      @default(0)
  avatarUrl  String?
  isMain     Boolean  @default(false)
  blizzardId Int?
  userId     String
  guildId    String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  user          User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  guild         Guild          @relation(fields: [guildId], references: [id], onDelete: Cascade)
  wishlistItems WishlistItem[]
  attendances   Attendance[]
  performances  Performance[]

  @@unique([name, realm, region, guildId])
}

// ─── Wishlist ───

model WishlistItem {
  id          String   @id @default(cuid())
  itemId      Int
  itemName    String
  itemIcon    String?
  itemSlot    String?
  itemLevel   Int?
  sourceBoss  String?
  sourceRaid  String?
  priority    Int      @default(0)
  note        String?  @db.Text
  obtained    Boolean  @default(false)
  characterId String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  character Character @relation(fields: [characterId], references: [id], onDelete: Cascade)

  @@unique([characterId, itemId])
}

// ─── Raid Events & Attendance ───

model RaidEvent {
  id          String   @id @default(cuid())
  title       String
  description String?  @db.Text
  raidName    String
  difficulty  String   @default("Heroic")
  startTime   DateTime
  endTime     DateTime
  createdById String
  guildId     String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  guild       Guild        @relation(fields: [guildId], references: [id], onDelete: Cascade)
  attendances Attendance[]
  raidLogs    RaidLog[]
}

model Attendance {
  id          String           @id @default(cuid())
  status      AttendanceStatus @default(TENTATIVE)
  note        String?
  characterId String
  raidEventId String
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  character Character @relation(fields: [characterId], references: [id], onDelete: Cascade)
  raidEvent RaidEvent @relation(fields: [raidEventId], references: [id], onDelete: Cascade)

  @@unique([characterId, raidEventId])
}

// ─── Raid Logs & Performance ───

model RaidLog {
  id          String    @id @default(cuid())
  reportCode  String
  title       String?
  raidName    String?
  startTime   DateTime?
  endTime     DateTime?
  raidEventId String?
  guildId     String
  fetchedAt   DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  guild        Guild         @relation(fields: [guildId], references: [id], onDelete: Cascade)
  raidEvent    RaidEvent?    @relation(fields: [raidEventId], references: [id], onDelete: SetNull)
  performances Performance[]

  @@unique([reportCode, guildId])
}

model Performance {
  id            String   @id @default(cuid())
  characterId   String
  raidLogId     String
  encounterName String
  encounterId   Int
  difficulty    Int
  dps           Float?
  hps           Float?
  deaths        Int      @default(0)
  rankPercent   Float?
  duration      Int?
  spec          String?
  createdAt     DateTime @default(now())

  character Character @relation(fields: [characterId], references: [id], onDelete: Cascade)
  raidLog   RaidLog   @relation(fields: [raidLogId], references: [id], onDelete: Cascade)

  @@unique([characterId, raidLogId, encounterId, difficulty])
}
